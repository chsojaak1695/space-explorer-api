# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── NASA API ─────────────────────────────────────────────
# Register a free key at: https://api.nasa.gov
NASA_API_KEY=DEMO_KEY

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/space_explorer

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cache TTLs (seconds) ─────────────────────────────────
APOD_CACHE_TTL=86400
MARS_CACHE_TTL=3600
NEO_CACHE_TTL=3600

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
